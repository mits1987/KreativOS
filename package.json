import React, { useState, useEffect, useRef } from 'react'
import { Search, Download, Trash2, Star, CheckCircle, XCircle, RefreshCw, ExternalLink, Cpu, HardDrive, Zap } from 'lucide-react'
import clsx from 'clsx'
import useStore from '../store'
import api from '../utils/api'

const SPEED_COLOR = { Fastest: '#10b981', Fast: '#6366f1', Medium: '#f59e0b', Slow: '#ef4444' }
const TAG_COLOR   = { Recommended:'#8b5cf6', Lightweight:'#10b981', Popular:'#f59e0b', Coding:'#06b6d4', Reasoning:'#ec4899', Pro_Coding:'#ef4444', Tiny:'#84cc16', Microsoft:'#0ea5e9' }

function ModelCard({ model, installed, onInstall, onDelete, installing, progress }) {
  const isInstalling = installing === model.id
  const isInstalled  = installed.includes(model.ollama_name || model.name?.toLowerCase())
  const tagColor = TAG_COLOR[model.tag?.replace(' ','')] || '#6366f1'
  const speedColor = SPEED_COLOR[model.speed] || '#6366f1'

  return (
    <div className={clsx('glass rounded-xl border p-4 transition-all flex flex-col gap-3',
      isInstalled ? 'border-accent-green/30' : 'border-white/10 hover:border-white/20')}>
      <div className="flex items-start justify-between gap-2">
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2 flex-wrap">
            <span className="text-sm font-semibold text-white">{model.name}</span>
            {model.tag && (
              <span className="text-xs px-2 py-0.5 rounded-full font-medium"
                style={{ background: tagColor+'22', color: tagColor }}>{model.tag}</span>
            )}
            {isInstalled && <CheckCircle size={13} className="text-accent-green flex-shrink-0" />}
          </div>
          {model.id && (
            <div className="text-xs text-slate-600 font-mono mt-0.5 truncate">{model.id}</div>
          )}
        </div>
      </div>

      {/* Specs */}
      <div className="flex items-center gap-3 flex-wrap">
        {model.size && (
          <span className="flex items-center gap-1 text-xs text-slate-500">
            <HardDrive size={11} />{model.size}
          </span>
        )}
        {model.ram && (
          <span className="flex items-center gap-1 text-xs text-slate-500">
            <Cpu size={11} />{model.ram} RAM
          </span>
        )}
        {model.speed && (
          <span className="flex items-center gap-1 text-xs font-medium" style={{ color: speedColor }}>
            <Zap size={11} />{model.speed}
          </span>
        )}
        {model.downloads && (
          <span className="text-xs text-slate-600">↓ {(model.downloads/1000).toFixed(0)}k</span>
        )}
      </div>

      {/* Progress bar */}
      {isInstalling && (
        <div className="space-y-1">
          <div className="flex justify-between text-xs text-slate-500">
            <span>{progress?.status || 'Starting…'}</span>
            <span>{progress?.pct || 0}%</span>
          </div>
          <div className="h-1.5 bg-surface-3 rounded-full overflow-hidden">
            <div className="h-full bg-accent-purple rounded-full transition-all duration-300"
              style={{ width: `${progress?.pct || 0}%` }} />
          </div>
        </div>
      )}

      {/* Actions */}
      <div className="flex items-center gap-2 mt-auto">
        {isInstalled ? (
          <>
            <button onClick={() => useStore.getState().setSelectedModel(model.ollama_name || '')}
              className="flex-1 text-xs py-1.5 rounded-lg bg-accent-green/15 text-accent-green hover:bg-accent-green/25 transition-all font-medium">
              Use this model
            </button>
            <button onClick={() => onDelete(model.ollama_name || model.id)}
              className="p-1.5 text-slate-600 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition-all">
              <Trash2 size={13} />
            </button>
          </>
        ) : isInstalling ? (
          <div className="flex-1 text-xs py-1.5 rounded-lg bg-accent-purple/15 text-accent-purple text-center font-medium">
            Downloading…
          </div>
        ) : (
          <>
            <button onClick={() => onInstall(model)}
              className="flex-1 flex items-center justify-center gap-1.5 text-xs py-1.5 rounded-lg bg-accent-purple/15 text-accent-purple hover:bg-accent-purple/25 transition-all font-medium">
              <Download size={12} /> Install
            </button>
            {model.url && (
              <a href={model.url} target="_blank" rel="noopener noreferrer"
                className="p-1.5 text-slate-600 hover:text-white hover:bg-surface-3 rounded-lg transition-all">
                <ExternalLink size={13} />
              </a>
            )}
          </>
        )}
      </div>
    </div>
  )
}

export default function ModelHubView() {
  const { models, setModels, setSelectedModel } = useStore()
  const [tab, setTab] = useState('featured')       // featured | search | installed
  const [query, setQuery] = useState('')
  const [featured, setFeatured] = useState([])
  const [searchResults, setSearchResults] = useState([])
  const [searching, setSearching] = useState(false)
  const [installing, setInstalling] = useState(null)  // model id being installed
  const [progress, setProgress] = useState({})
  const [notification, setNotification] = useState(null)
  const [modelDetails, setModelDetails] = useState({})

  const notify = (msg, type = 'success') => {
    setNotification({ msg, type })
    setTimeout(() => setNotification(null), 3500)
  }

  useEffect(() => {
    // Load featured models
    fetch('/api/hub/featured').then(r=>r.json()).then(d => setFeatured(d.models || []))
  }, [])

  const refreshModels = async () => {
    const d = await api.models()
    setModels(d.models || [])
  }

  const search = async () => {
    if (!query.trim()) return
    setSearching(true)
    setTab('search')
    try {
      const d = await fetch(`/api/hub/search?q=${encodeURIComponent(query)}&limit=12`).then(r=>r.json())
      // Fetch ollama names for results
      const enriched = await Promise.all((d.results||[]).map(async m => {
        const nr = await fetch(`/api/hub/ollama-name?hf_id=${encodeURIComponent(m.id)}`).then(r=>r.json())
        return { ...m, ollama_name: nr.ollama_name }
      }))
      setSearchResults(enriched)
    } catch(e) {
      notify('Search failed: ' + e.message, 'error')
    } finally {
      setSearching(false)
    }
  }

  const installModel = async (model) => {
    // Get ollama name
    let ollamaName = model.ollama_name
    if (!ollamaName) {
      const nr = await fetch(`/api/hub/ollama-name?hf_id=${encodeURIComponent(model.id)}`).then(r=>r.json())
      ollamaName = nr.ollama_name
    }
    if (!ollamaName) { notify('Could not determine Ollama model name', 'error'); return }

    setInstalling(model.id)
    setProgress({ pct: 0, status: 'Starting download…' })

    try {
      const resp = await fetch('/api/hub/pull', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ model_name: ollamaName, hf_model_id: model.id }),
      })
      const reader = resp.body.getReader()
      const decoder = new TextDecoder()
      let buf = ''
      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        buf += decoder.decode(value, { stream: true })
        const lines = buf.split('\n')
        buf = lines.pop() || ''
        for (const line of lines) {
          if (line.startsWith('data: ')) {
            const raw = line.slice(6)
            if (raw === '[DONE]') break
            try {
              const d = JSON.parse(raw)
              if (d.status === 'error') { notify('Download failed: ' + d.error, 'error'); break }
              setProgress({ pct: d.pct || 0, status: d.status || '' })
            } catch {}
          }
        }
      }
      await refreshModels()
      notify(`✅ ${model.name} installed! Select it in Settings or Chat.`)
    } catch(e) {
      notify('Install failed: ' + e.message, 'error')
    } finally {
      setInstalling(null)
      setProgress({})
    }
  }

  const deleteModel = async (name) => {
    if (!confirm(`Delete ${name} from Ollama?`)) return
    await fetch(`/api/hub/delete/${encodeURIComponent(name)}`, { method: 'DELETE' })
    await refreshModels()
    notify(`${name} deleted`)
  }

  const installedNames = models.map(m => m.toLowerCase())
  const displayModels  = tab === 'search' ? searchResults : tab === 'installed'
    ? featured.filter(m => installedNames.includes((m.ollama_name||'').toLowerCase()))
    : featured

  return (
    <div className="flex flex-col h-full overflow-y-auto">
      <div className="max-w-4xl mx-auto w-full px-6 py-8">

        {/* Header */}
        <div className="mb-6">
          <div className="flex items-center gap-3 mb-1">
            <span className="text-2xl">🤗</span>
            <h1 className="text-xl font-bold text-white">Model Hub</h1>
            <span className="text-xs px-2 py-0.5 rounded-full bg-accent-purple/20 text-accent-purple">HuggingFace</span>
          </div>
          <p className="text-slate-500 text-sm">Browse, download and manage GGUF models optimised for CPU. All models run locally via Ollama.</p>
        </div>

        {/* Notification */}
        {notification && (
          <div className={clsx('mb-4 px-4 py-3 rounded-xl text-sm border flex items-center gap-2',
            notification.type === 'error'
              ? 'bg-red-500/10 border-red-500/30 text-red-400'
              : 'bg-green-500/10 border-green-500/30 text-green-400')}>
            {notification.type === 'error' ? <XCircle size={14}/> : <CheckCircle size={14}/>}
            {notification.msg}
          </div>
        )}

        {/* Search bar */}
        <div className="flex gap-2 mb-5">
          <div className="relative flex-1">
            <Search size={14} className="absolute left-3 top-3 text-slate-500" />
            <input className="input-base w-full pl-9"
              placeholder="Search HuggingFace for GGUF models… e.g. llama, mistral, qwen"
              value={query}
              onChange={e => setQuery(e.target.value)}
              onKeyDown={e => e.key === 'Enter' && search()}
            />
          </div>
          <button onClick={search} disabled={searching || !query.trim()}
            className="btn-primary flex items-center gap-2 px-5 disabled:opacity-40">
            {searching ? <RefreshCw size={14} className="animate-spin"/> : <Search size={14}/>}
            Search
          </button>
        </div>

        {/* Tabs */}
        <div className="flex gap-1 mb-5 bg-surface-2 p-1 rounded-xl w-fit">
          {[
            { id: 'featured', label: '⭐ Featured' },
            { id: 'search',   label: `🔍 Results${searchResults.length ? ` (${searchResults.length})` : ''}` },
            { id: 'installed',label: `✅ Installed (${models.length})` },
          ].map(t => (
            <button key={t.id} onClick={() => setTab(t.id)}
              className={clsx('px-4 py-1.5 rounded-lg text-xs font-medium transition-all',
                tab === t.id ? 'bg-surface-4 text-white' : 'text-slate-500 hover:text-white')}>
              {t.label}
            </button>
          ))}
        </div>

        {/* CPU notice */}
        <div className="mb-4 flex items-start gap-2 px-4 py-3 rounded-xl bg-amber-500/10 border border-amber-500/20 text-xs text-amber-400">
          <Cpu size={14} className="flex-shrink-0 mt-0.5"/>
          <span>All models below are CPU-friendly GGUF files. For your 24GB Oracle VM, models under 8GB file size work best. "Fastest" models respond in seconds; "Medium" takes ~1 min per response.</span>
        </div>

        {/* Model grid */}
        {searching ? (
          <div className="flex items-center justify-center py-16 gap-3 text-slate-500">
            <RefreshCw size={16} className="animate-spin"/>
            Searching HuggingFace…
          </div>
        ) : displayModels.length === 0 ? (
          <div className="text-center py-16 text-slate-600 text-sm">
            {tab === 'search' ? 'Search for models above.' : tab === 'installed' ? 'No featured models installed yet.' : 'No models found.'}
          </div>
        ) : (
          <div className="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {displayModels.map(model => (
              <ModelCard
                key={model.id}
                model={model}
                installed={installedNames}
                onInstall={installModel}
                onDelete={deleteModel}
                installing={installing}
                progress={installing === model.id ? progress : null}
              />
            ))}
          </div>
        )}

        {/* Installed models list */}
        {tab === 'installed' && models.length > 0 && (
          <div className="mt-6">
            <div className="text-xs text-slate-500 uppercase tracking-wider mb-3">All Ollama models on this VM</div>
            <div className="space-y-2">
              {models.map(m => (
                <div key={m} className="flex items-center justify-between p-3 glass rounded-xl border border-white/10">
                  <div className="flex items-center gap-3">
                    <CheckCircle size={14} className="text-accent-green"/>
                    <span className="text-sm font-mono text-white">{m}</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <button onClick={() => setSelectedModel(m)}
                      className="text-xs px-3 py-1 rounded-lg bg-accent-purple/15 text-accent-purple hover:bg-accent-purple/25 transition-all">
                      Use
                    </button>
                    <button onClick={() => deleteModel(m)}
                      className="p-1.5 text-slate-600 hover:text-red-400 transition-all">
                      <Trash2 size={13}/>
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  )
}
