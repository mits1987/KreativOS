# KreativOS Environment Variables
# Copy this file to .env and fill in your values

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Workspace directory for agent files
WORKSPACE_DIR=./workspace

# Telegram bot integration (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Enable auth (set to "true" to require login)
AUTH_REQUIRED=false

# Voice model path (optional, for offline STT)
VOSK_MODEL_PATH=./models/vosk-model-small-en-us
